<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/colorBackground</item>
    </style>

    <style name="ThemeOverlay.Auth.Login.Fields" parent="">
        <item name="colorPrimary">@color/white</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/auth_label_login</item>
    </style>

    <style name="Auth.TextInputLayout.Login" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundMode">none</item>
        <item name="android:textColorHint">@color/auth_label_login</item>
        <item name="hintTextColor">@color/auth_label_login</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
    </style>

    <style name="Auth.TextInputLayout.Signup" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundMode">none</item>
        <item name="android:textColorHint">@color/auth_label_signup</item>
        <item name="hintTextColor">@color/auth_label_signup</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
    </style>

    <style name="Auth.TextInputEdit.Login" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorHint">@color/auth_label_login</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Auth.TextInputEdit.Signup" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/nmims_text_primary</item>
        <item name="android:textColorHint">@color/auth_label_signup</item>
        <item name="android:textSize">15sp</item>
    </style>

</resources>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Claim Item"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/colorPrimaryDark"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Answer the following security questions so the poster can verify you are the real owner."
        android:textSize="14sp"
        android:textColor="@color/colorTextSecondary"
        android:layout_marginBottom="16dp"/>

    <!-- Color -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Q1. What is the color of the item?"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/etClaimColor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. Matte Black"
        android:inputType="text"
        android:layout_marginBottom="16dp"/>

    <!-- Brand -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Q2. What is the brand?"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/etClaimBrand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. JBL"
        android:inputType="text"
        android:layout_marginBottom="16dp"/>

    <!-- Identifying Mark -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Q3. Any specific identifying marks?"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/etClaimMark"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. Scratch on the left side"
        android:inputType="text"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btnClaimCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            style="?android:attr/borderlessButtonStyle"
            android:textColor="@color/colorTextSecondary"/>

        <Button
            android:id="@+id/btnClaimSubmit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Submit Claim"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/white"/>
    </LinearLayout>
</LinearLayout>

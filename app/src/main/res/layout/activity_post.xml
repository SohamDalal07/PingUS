<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        app:title="Report an Item"
        app:titleTextColor="@color/colorTextOnPrimary"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:importantForAccessibility="no">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Lost / Found toggle ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_seg_track"
                android:padding="3dp">

                <RadioGroup
                    android:id="@+id/rg_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rb_lost"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:background="@drawable/seg_selector"
                            android:button="@null"
                            android:gravity="center"
                            android:text="I Lost It"
                            android:textColor="@color/home_hint_text"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <RadioButton
                            android:id="@+id/rb_found"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:background="@drawable/seg_selector"
                            android:button="@null"
                            android:gravity="center"
                            android:text="I Found It"
                            android:textColor="@color/home_hint_text"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                </RadioGroup>

            </FrameLayout>

            <!-- ── Item Name ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Item name *"
                android:textColor="@color/colorTextPrimary"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etItemName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="e.g. Black JBL earbuds"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="textCapSentences"
                android:maxLength="60"
                android:layout_marginBottom="18dp"/>

            <!-- ── Category Personal ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvPersonalLabel"
                android:text="Category — Personal items"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/spinnerPersonal"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="12dp"
                android:spinnerMode="dropdown"/>

            <!-- ── Category Academic ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvAcademicLabel"
                android:text="Category — Academic / Campus items"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/spinnerAcademic"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="18dp"
                android:spinnerMode="dropdown"/>

            <!-- ── Last seen location ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last seen location *"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/spinnerLocation"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="18dp"
                android:spinnerMode="dropdown"/>

            <!-- ── Tip strip ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/colorTipBg"
                android:padding="10dp"
                android:layout_marginBottom="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Valuable item? Hand to hostel warden or campus security first, then post here."
                    android:textColor="@color/colorTipText"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4"/>

            </LinearLayout>

            <!-- ── Photo optional ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Photo (optional)"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:id="@+id/layoutPhotoTap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="18dp">

                <Button
                    android:id="@+id/btnSelectImage"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="📷 Select Image"
                    android:textColor="@color/colorTextOnPrimary"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    android:layout_marginBottom="12dp"/>

                <ImageView
                    android:id="@+id/ivSelectedImage"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_seg_track"/>

            </LinearLayout>

            <!-- ── Description optional ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description (optional)"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:hint="Any details that help identify the item…"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:inputType="textMultiLine|textCapSentences"
                android:gravity="top|start"
                android:maxLength="200"
                android:layout_marginBottom="28dp"/>

            <!-- ── Post button ── -->
            <Button
                android:id="@+id/btnPostReport"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Post report"
                android:textColor="@color/colorTextOnPrimary"
                android:textSize="15sp"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Lost report image uploads from PostActivity ("I Lost It" flow)
    match /lost_reports/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 10 * 1024 * 1024; // 10MB
      allow delete: if request.auth != null;
    }

    // Legacy path support (if any previous uploads used item-images/)
    match /item-images/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 10 * 1024 * 1024; // 10MB limit
      allow delete: if request.auth != null;
    }

    // Keep auth-only fallback for any other path in this bucket.
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}

